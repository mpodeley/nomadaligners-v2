    <header class="header">
        <nav class="container nav">
            <div class="hamburger" aria-label="Abrir menú" role="button" tabindex="0">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </div>

            <a href="/" class="logo">{{ site.name }}</a>

            <ul class="nav-menu">
                {% for item in nav.main %}
                  {% if item.dropdown %}
                <li class="dropdown">
                    <a href="#" class="dropbtn">{{ item.label }} ▾</a>
                    <div class="dropdown-content">
                      {% for sub in item.dropdown %}
                        <a href="{{ sub.url }}">{{ sub.label }}</a>
                      {% endfor %}
                    </div>
                </li>
                  {% else %}
                <li><a href="{{ item.url }}">{{ item.label }}</a></li>
                  {% endif %}
                {% endfor %}
            </ul>

            <a href="https://wa.me/{{ site.whatsappNumber }}?text={{ site.whatsappDefaultText | urlencode }}" target="_blank" rel="noopener" class="btn-whatsapp-nav" aria-label="WhatsApp" data-cta="whatsapp-nav">
                <img src="/img/WhatsApp.svg" alt="WhatsApp" class="whatsapp-icon">
            </a>
        </nav>
    </header>
