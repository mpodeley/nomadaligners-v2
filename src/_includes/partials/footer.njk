    <footer class="footer">
        <div class="container">
            {% if nav.footerGroups %}
            <div class="footer-grid">
                {% for group in nav.footerGroups %}
                <nav class="footer-col" aria-label="{{ group.title }}">
                    <h3 class="footer-col-title">{{ group.title }}</h3>
                    <ul>
                        {% for link in group.links %}<li><a href="{{ link.url }}">{{ link.label }}</a></li>{% endfor %}
                    </ul>
                </nav>
                {% endfor %}
            </div>
            {% endif %}
            <div class="footer-bottom">
                <p>© <span id="year"></span> {{ site.name }} · {{ site.doctorName }}</p>
                <p class="social-links">📷 {% for ig in site.instagram %}<a href="{{ ig.url }}" target="_blank" rel="noopener">{{ ig.handle }}</a>{% if not loop.last %} · {% endif %}{% endfor %}</p>
            </div>
        </div>
    </footer>
