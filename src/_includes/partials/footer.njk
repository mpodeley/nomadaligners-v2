    <footer class="footer">
        <div class="container">
            {% if nav.footer %}
            <nav class="footer-nav" aria-label="Recursos para pacientes">
                <p class="footer-nav-title">Para pacientes en tratamiento:</p>
                <ul>
                    {% for item in nav.footer %}<li><a href="{{ item.url }}">{{ item.label }}</a></li>{% endfor %}
                </ul>
            </nav>
            {% endif %}
            <p>© <span id="year"></span> {{ site.name }} | {{ site.doctorName }}. Todos los derechos reservados.</p>
            <div class="social-links">
                <p>📷 {% for ig in site.instagram %}<a href="{{ ig.url }}" target="_blank" rel="noopener">{{ ig.handle }}</a>{% if not loop.last %} · {% endif %}{% endfor %}</p>
            </div>
        </div>
    </footer>
