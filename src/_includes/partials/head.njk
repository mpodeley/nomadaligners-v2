    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}{% if title_suffix !== false %} | {{ site.name }}{% endif %}</title>
    <meta name="description" content="{{ description }}">
    <link rel="canonical" href="{{ site.baseUrl }}{{ page.url }}">
    <meta name="robots" content="{{ robots or 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1' }}">
    <meta name="theme-color" content="{{ site.themeColor }}">

    {% if hreflang %}
      {% for alt in hreflang %}
    <link rel="alternate" hreflang="{{ alt.lang }}" href="{{ site.baseUrl }}{{ alt.url }}">
      {% endfor %}
    {% endif %}

    <link rel="icon" href="/img/favicon.png" type="image/png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    {% if page.url == "/" or page.url == "/en/" %}
    <link rel="preload" as="image" href="{{ ogImage or site.ogImage }}" fetchpriority="high">
    {% endif %}

    <meta property="og:locale" content="{{ ogLocale or site.ogLocale }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:title" content="{{ ogTitle or title }}{% if title_suffix !== false %} | {{ site.name }}{% endif %}">
    <meta property="og:description" content="{{ ogDescription or description }}">
    <meta property="og:url" content="{{ site.baseUrl }}{{ page.url }}">
    <meta property="og:image" content="{{ site.baseUrl }}{{ ogImage or site.ogImage }}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ ogTitle or title }}{% if title_suffix !== false %} | {{ site.name }}{% endif %}">
    <meta name="twitter:description" content="{{ ogDescription or description }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}{{ ogImage or site.ogImage }}">

    <script type="application/ld+json">{{ schema.dentist | jsonify | safe }}</script>
    <script type="application/ld+json">{{ schema.person | jsonify | safe }}</script>
    {% if page.url and page.url !== "/" and h1 %}
    <script type="application/ld+json">{ "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "{{ site.baseUrl }}/" }, { "@type": "ListItem", "position": 2, "name": {{ h1 | jsonify | safe }}, "item": "{{ site.baseUrl }}{{ page.url }}" }] }</script>
    <script type="application/ld+json">{ "@context": "https://schema.org", "@type": "MedicalWebPage", "name": {{ (h1 or title) | jsonify | safe }}, "headline": {{ (h1 or title) | jsonify | safe }}, "description": {{ description | jsonify | safe }}, "url": "{{ site.baseUrl }}{{ page.url }}", "inLanguage": "{{ lang or site.defaultLang }}", "datePublished": "{{ site.siteLastUpdatedISO }}", "dateModified": "{{ site.siteLastUpdatedISO }}", "author": { "@type": "Person", "name": {{ site.doctorName | jsonify | safe }}, "jobTitle": {{ site.doctorJobTitle | jsonify | safe }} }, "publisher": { "@id": "{{ site.baseUrl }}#dentist" }, "primaryImageOfPage": "{{ site.baseUrl }}{{ ogImage or site.ogImage }}", "isPartOf": { "@type": "WebSite", "name": {{ site.name | jsonify | safe }}, "url": "{{ site.baseUrl }}" }, "specialty": { "@type": "MedicalSpecialty", "name": "Orthodontic" }{% if faqs %}, "mainContentOfPage": { "@type": "WebPageElement", "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".hero-content p", ".faq-answer"] } }{% endif %} }</script>
    {% endif %}
    {% if faqs %}
    <script type="application/ld+json">{ "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{% for f in faqs %}{ "@type": "Question", "name": {{ f.q | jsonify | safe }}, "acceptedAnswer": { "@type": "Answer", "text": {{ f.a | jsonify | safe }} } }{% if not loop.last %},{% endif %}{% endfor %}] }</script>
    {% endif %}
    {% if extraSchema %}
      {% for s in extraSchema %}
    <script type="application/ld+json">{{ s | jsonify | safe }}</script>
      {% endfor %}
    {% endif %}
